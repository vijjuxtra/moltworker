{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "moltworker",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-01",
  "compatibility_flags": ["nodejs_compat_v2"],
  
  [[kv_namespaces]]
  binding = "MY_KV"
  id = "CHAT_KV"  // ← ADD YOUR KV ID
  
  [vars]
  LLAMA_URL = "good-agent-vlt.vijjubox9969.workers.dev"  // ← YOUR LLAMA URL
  
  [sandbox]
  enabled = true
}

