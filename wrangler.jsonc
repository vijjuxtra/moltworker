{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "moltworker",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-01",
  "compatibility_flags": ["nodejs_compat_v2"],
  
  [[kv_namespaces]]
  binding = "MY_KV"
  id = "your-kv-namespace-id-here"  // ← ADD YOUR KV ID
  
  [vars]
  LLAMA_URL = "https://your-llama-worker.youraccount.workers.dev/v1"  // ← YOUR LLAMA URL
  
  [sandbox]
  enabled = true
}

